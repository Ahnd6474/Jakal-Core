{
  "schema_version": 1,
  "prerequisites": [
    {
      "id": "vulkan-support",
      "label": "Install/repair Vulkan support",
      "description": "Repair or install GPU vendor Vulkan components used by Jakal's Vulkan backend.",
      "local_installer_globs": [
        "prereqs/vulkan-support/*.msi",
        "prereqs/vulkan-support/*.exe",
        "prereqs/vulkan-support/*.zip",
        "prereqs/vulkan-support/sdk/*.exe",
        "prereqs/vulkan-support/sdk/*.zip"
      ],
      "runtime_tool_globs": [
        "prereqs/vulkan-support/bin/glslc.exe",
        "prereqs/vulkan-support/bin/glslangValidator.exe",
        "tools/vulkan/bin/glslc.exe",
        "tools/vulkan/bin/glslangValidator.exe"
      ],
      "support_urls": [
        "https://vulkan.lunarg.com/sdk/home",
        "https://www.nvidia.com/Download/index.aspx",
        "https://www.intel.com/content/www/us/en/download-center/home.html",
        "https://www.amd.com/en/support/download/drivers.html"
      ]
    },
    {
      "id": "intel-level-zero-runtime",
      "label": "Install Intel Level Zero runtime",
      "description": "Install or repair Intel GPU runtime support for Level Zero.",
      "local_installer_globs": [
        "prereqs/intel-level-zero-runtime/*.msi",
        "prereqs/intel-level-zero-runtime/*.exe",
        "prereqs/intel-level-zero-runtime/*.zip"
      ],
      "runtime_tool_globs": [],
      "support_urls": [
        "https://www.intel.com/content/www/us/en/download-center/home.html"
      ]
    },
    {
      "id": "opencl-runtime",
      "label": "Install OpenCL runtime",
      "description": "Install or repair a vendor OpenCL runtime as accelerator fallback.",
      "local_installer_globs": [
        "prereqs/opencl-runtime/*.msi",
        "prereqs/opencl-runtime/*.exe",
        "prereqs/opencl-runtime/*.zip"
      ],
      "runtime_tool_globs": [],
      "support_urls": [
        "https://www.intel.com/content/www/us/en/download-center/home.html",
        "https://www.nvidia.com/Download/index.aspx",
        "https://www.amd.com/en/support/download/drivers.html"
      ]
    },
    {
      "id": "skip-existing-drivers",
      "label": "Skip and use existing drivers",
      "description": "Keep the current machine drivers and install only the Jakal runtime.",
      "local_installer_globs": [],
      "runtime_tool_globs": [],
      "support_urls": []
    }
  ]
}
